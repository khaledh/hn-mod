{
  "manifest_version": 3,
  "name": "Hacker News Mod",
  "version": "1.2.1",
  "description": "Enhances Hacker News with new story indicators, rank trends, site icons, story dimming, and an unseen stories panel.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab", "storage"
  ],
  "host_permissions": [
    "https://news.ycombinator.com/*",
    "https://hacker-news.firebaseio.com/*"
  ],
  "background": {
    "service_worker": "hot-reload.js"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "key": ""
}
