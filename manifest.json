{
  "manifest_version": 3,
  "name": "Hacker News Mod",
  "version": "1.1",
  "description": "Chrome extension for customizing Hacker News.",
  "permissions": [
    "activeTab", "storage", "alarms"
  ],
  "host_permissions": [
    "https://news.ycombinator.com/*"
  ],
  "background": {
    "service_worker": "hot-reload.js"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
